NODE_ENV=development
PORT=5000

# Required in production
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=2h

# DB Mode:
# - leave empty for auto (uses Postgres when NODE_ENV=production and DATABASE_URL is set)
# - or force: postgres | json-files
DB_MODE=

# Local Postgres (adjust as needed)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transpo

# Render Postgres typically requires SSL in production
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_MS=30000
DATABASE_POOL_CONN_TIMEOUT_MS=10000
