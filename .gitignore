# Node dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/.next/
frontend/out/

# Local environment files
.env
.env.*
!.env.example
!.env.local.example
# Production env files contain secrets - never commit
backend/.env.production
frontend/.env.production

# Backend database — ignore runtime data but keep seed files
backend/data/_backups/
backend/data/*.tmp
# Keep the seed data files (users, buses, etc.)
!backend/data/users.json
!backend/data/buses.json
!backend/data/hubs.json
!backend/data/schedules.json
!backend/data/bus_fares.json
!backend/data/pricing_routes.json
!backend/data/delivery_fees.json

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Root-level utility/test scripts
api_test.ps1
check_hash.js
fix_checksum.js
gen_hash.js
reset_admin_password.js
smoke_test.ps1
verify_*.ps1
preview.html
