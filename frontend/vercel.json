{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://transpo-hub-api.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://transpo-hub-api.onrender.com/socket.io/:path*"
    }
  ]
}
